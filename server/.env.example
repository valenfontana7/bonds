PORT=3001
PUBLIC_APP_URL=https://tu-dominio.com
# Orígenes permitidos (separados por coma). En dev se agrega http://localhost:4200 automáticamente.
CLIENT_ORIGIN=https://tu-dominio.com,http://localhost:4200
STATIC_DIR=../dist/bonds-app/browser

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@tu-dominio.com

# Upstash / Vercel KV (obligatorio en Vercel)
# Usá la URL REST https://… y el token de lectura/escritura (no rediss:// ni token read-only).
# Vercel: Project → Storage → tu KV → .env.local / Connect
# Upstash: Database → REST API → UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth + sync
JWT_SECRET=genera-un-string-largo-aleatorio-distinto-al-cron

# Gemini (importación con IA)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Solo Vercel Cron
CRON_SECRET=genera-un-string-largo-aleatorio

# Hora local del dispositivo (0-23) a partir de la cual enviar el digest diario
DEFAULT_DIGEST_HOUR=9

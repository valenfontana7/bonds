PORT=3001
PUBLIC_APP_URL=https://tu-dominio.com
CLIENT_ORIGIN=https://tu-dominio.com
STATIC_DIR=../dist/bonds-app/browser

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@tu-dominio.com

# Upstash / Vercel KV (obligatorio en Vercel)
# Vercel Storage suele crear KV_REST_API_URL y KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Auth + sync
JWT_SECRET=genera-un-string-largo-aleatorio-distinto-al-cron

# Gemini (importación con IA)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Solo Vercel Cron
CRON_SECRET=genera-un-string-largo-aleatorio

# Hora local del dispositivo (0-23) a partir de la cual enviar el digest diario
DEFAULT_DIGEST_HOUR=9

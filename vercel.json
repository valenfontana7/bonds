{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/bonds-app/browser",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "lib/**",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/digest",
      "schedule": "0 17 * * *"
    }
  ]
}

{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/bonds-app/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/digest",
      "schedule": "*/15 * * * *"
    }
  ]
}

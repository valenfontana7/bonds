{
  "name": "bonds-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:pwa": "ng build && npx http-server dist/bonds-app/browser -p 8080 -c-1",
    "build:prod": "ng build && npm install --prefix server && npm run start --prefix server",
    "server": "npm run start --prefix server",
    "server:dev": "npm run dev --prefix server",
    "server:vapid": "npm run vapid --prefix server",
    "server:install": "npm install --prefix server",
    "icons": "node scripts/generate-icons.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@angular/service-worker": "^19.2.0",
    "d3": "^7.9.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "web-push": "^3.6.7",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.27",
    "@angular/cli": "^19.2.27",
    "@angular/compiler-cli": "^19.2.0",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.35.1",
    "typescript": "~5.7.2"
  }
}
